ig_beta  <- c(1, 2, 3)
ht_mu   <- 0
ht_df   <- c(3, 5, 7)
ht_scale <- c(0.5, 1.0)
results <- list()
idx <- 1
for (a in ig_alpha) {
for (b in ig_beta) {
