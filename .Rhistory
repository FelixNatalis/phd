set.seed(144)
### shrinkage of horsechoe priors
set.seed(1)
N <- 100000
# Half-normal prior on sigma_f
sigma_halfnorm <- abs(rnorm(N, mean = 0, sd = 1))
# Half-t prior on sigma_f (df = 3)
sigma_halft <- abs(rt(N, df = 3))
# Induced variance
var_halfnorm <- sigma_halfnorm^2
var_halft <- sigma_halft^2
# Plot densities
par(mfrow=c(1,2))
plot(density(var_halfnorm), main="Induced prior on variance\nHalf-Normal on σ_f",
xlab=expression(sigma[f]^2), xlim=c(0,5))
abline(v=0, col="red")
plot(density(var_halft), main="Induced prior on variance\nHalf-t(3) on σ_f",
xlab=expression(sigma[f]^2), xlim=c(0,10))
abline(v=0, col="red")
