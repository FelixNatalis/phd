?dhalfT
# prior predictive redo
# squared exponential kernel
k_se <- function(x1, x2, lambda, sigma) {
outer(x1, x2, function(a, b)
(sigma^2) * exp(-(a - b)^2 / (2 * lambda^2))
)
}
x <- seq(0, 10, length.out = 200)
simulate_gp <- function(lambda, sigma) {
K <- k_se(x, x, lambda, sigma)
L <- chol(K + 1e-6 * diag(length(x)))
drop(t(L) %*% rnorm(length(x)))
}
# hyperparameter grids
ig_alpha <- c(1, 2, 3)
ig_beta  <- c(1, 2, 3)
ht_mu   <- 0
ht_df   <- c(3, 5, 7)
ht_scale <- c(0.5, 1.0)
results <- list()
set.seed(1)
idx <- 1
for (a in ig_alpha) {
for (b in ig_beta) {
for (df_ in ht_df) {
for (s in ht_scale) {
lambda_draw   <- 1 / rgamma(1, shape = a, rate = b) # inv-gamma
sigma_draw <- ht_mu + ht_scale * rhalfT(1, n = ht_df)#abs(rt(1, df = df_) * s) # half-t
f <- simulate_gp(lambda_draw, sigma_draw)
results[[idx]] <-
data.frame(x = x,
f = f,
lambda = lambda_draw,
sigma = sigma_draw,
alpha = a,
beta = b,
df = df_,
scale = s)
idx <- idx + 1
}
}
}
}
?varhalfT
# prior predictive redo
# squared exponential kernel
k_se <- function(x1, x2, lambda, sigma) {
