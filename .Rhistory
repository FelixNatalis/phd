plot(x, y, type = "l", lwd = 2,
main = paste0("Half-t Distribution (df = ", df, ", scale = ", scale, ")"),
xlab = "x", ylab = "density")
# install.packages("VaRES")   # if needed
library(VaRES)
# parameters for half-t
mu <- 0
df  <- 8
scale <- 2
# grid
x <- seq(0, 10, length.out = 500)
d_halfT_scaled <- function(x, df, mu, scale) {
z <- (x - mu) / scale
z[z < 0] <- NA                 # half-t has support z ≥ 0
dhalfT(z, n = df) / scale
}
y <- d_halfT_scaled(x, df, mu, scale)
plot(x, y, type = "l", lwd = 2,
main = paste0("Half-t Distribution (df = ", df, ", scale = ", scale, ")"),
xlab = "x", ylab = "density")
